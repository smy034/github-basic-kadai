      "source": [
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self):\n",
        "        print(f\"名前：{self.name} 年齢：{self.age}\")\n",
        "\n",
        "# インスタンス化する\n",
        "human = Human(\"花子\", 36)\n",
        "\n",
        "# 属性にアクセスし、値を出力する\n",
        "human.printinfo()\n"
      ],
